<% page_title = content_for(:title).presence || "H-Queue - Skip the line. Grab your table." %>
<% page_description = content_for(:description).presence || "Skip the line. Join the virtual queue at your favourite bars and restaurants, and get notified when your table is ready." %>

<title><%= page_title %></title>
<meta name="description" content="<%= page_description %>">
<meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no">
<meta name="apple-mobile-web-app-capable" content="yes">
<meta name="application-name" content="H-Queue">
<meta name="mobile-web-app-capable" content="yes">
<meta name="theme-color" content="#16324D">
<link rel="manifest" href="<%= pwa_manifest_path %>">
<%= csrf_meta_tags %>
<%= csp_meta_tag %>

<%= content_for(:head) %>

<%# Favicons — asset pipeline (fingerprint = cache-buster natif) %>
<%= favicon_link_tag "favicon.ico", sizes: "32x32" %>
<%= favicon_link_tag "favicon.svg", type: "image/svg+xml" %>
<%= favicon_link_tag "favicon.png", type: "image/png" %>
<%= favicon_link_tag "favicon.png", rel: "apple-touch-icon", type: "image/png" %>

<%# Open Graph (Facebook, LinkedIn, WhatsApp…) %>
<meta property="og:type" content="website">
<meta property="og:site_name" content="H-Queue">
<meta property="og:title" content="<%= page_title %>">
<meta property="og:description" content="<%= page_description %>">
<meta property="og:url" content="<%= request.original_url %>">
<meta property="og:image" content="<%= "#{request.base_url}/og-image.png" %>">
<meta property="og:image:width" content="1200">
<meta property="og:image:height" content="630">

<%# Twitter Card %>
<meta name="twitter:card" content="summary_large_image">

<%= stylesheet_link_tag "application", "data-turbo-track": "reload" %>
<%= javascript_importmap_tags %>