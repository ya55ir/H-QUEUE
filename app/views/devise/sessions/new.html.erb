<%= render "shared/page_title", title: "Sign in", subtitle: "Welcome Back." %>

<%= simple_form_for(resource, as: resource_name, url: session_path(resource_name)) do |f| %>
  <%= f.input :email,
              required: false,
              autofocus: true,
              input_html: { autocomplete: "email" } %>

  <%# Password : champ custom pour insérer l'icône reveal dans .field-control %>
  <div class="mb-3" data-controller="password-visibility">
    <%= f.label :password, class: "form-label" %>
    <div class="field-control">
      <%= f.input_field :password,
                        class: "form-control",
                        autocomplete: "current-password",
                        data: { password_visibility_target: "input" } %>
      <button type="button"
              class="field-icon field-icon-right"
              aria-label="Show password"
              data-action="password-visibility#toggle">
        <i class="fa-regular fa-eye" data-password-visibility-target="icon"></i>
      </button>
    </div>
  </div>

  <%= f.button :submit, "Sign in", class: "btn-primary w-100" %>
<% end %>

<div class="text-center">
  <%= link_to "Forgot password?", new_password_path(resource_name), class: "btn btn-link" %>
</div>