<%# Liste des venues.
     Locals :
       venues        (Array)
       mode          (Symbol) :search, :nearby ou :geolocated
       label         (String, nullable) — terme affiché dans le titre des résultats
       filter_params (Hash) — critères de la liste, propagés sur les liens des venues
%>
<% if label.blank? %>
  <%= render "shared/feedback",
        icon: "store",
        title: "No venues yet",
        subtitle: "Search a venue or share your location to see venues around you." %>
<% elsif venues.any? %>
  <h2 class="h5 mb-3">
    <%= pluralize(venues.count, "Venue") %>
    <span class="text-primary">“<%= label %>”</span>
  </h2>

  <% venues.each do |venue| %>
    <%= render "shared/venue_card", venue: venue,
          distance: (venue.distance.round(1) unless mode == :search),
          path: venue_path(venue, **filter_params) %>
  <% end %>
<% else %>
  <%= render "shared/feedback",
        icon: "magnifying-glass",
        title: "No venues found",
        subtitle: "Try another name or address." %>
<% end %>