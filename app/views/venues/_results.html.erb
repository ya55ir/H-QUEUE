<% if query.blank? %>
  <%= render "shared/feedback",
        icon: "store",
        title: "No venues yet",
        subtitle: "Search a venue or share your location to see venues around you." %>
<% elsif venues.any? %>
  <h2 class="h5 mb-3">
    <%= pluralize(venues.count, "Venue") %>
    <span class="text-primary">“<%= query %>”</span>
  </h2>

  <% venues.each do |venue| %>
    <% if local_assigns[:near] %>
      <%= render "shared/venue_card", venue: venue,
          distance: venue.distance.round(1),
          path: venue_path(venue, near_venue_id: params[:near_venue_id]) %>
    <% else %>
      <%= render "shared/venue_card", venue: venue,
          path: venue_path(venue, query: query) %>
    <% end %>
  <% end %>
<% else %>
  <%= render "shared/feedback",
        icon: "magnifying-glass",
        title: "No venues found",
        subtitle: "Try another name or address." %>
<% end %>
