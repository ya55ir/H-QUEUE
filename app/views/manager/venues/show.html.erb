<%= render "shared/page_title", title: @venue.name, subtitle: "Manage your virtual queue" %>

<% @queue_entries_by_status.each do |status, entries| %>
  <h2 class="h5 mb-2"><%= status.to_s.capitalize %> (<%= entries.size %>)</h2>

  <% if entries.any? %>
    <% entries.each_with_index do |entry, index| %>
      <div class="card mb-2">
        <div class="card-body d-flex justify-content-between align-items-center">
          <div>
            <p class="mb-0 fw-bold">#<%= index + 1 %> · <%= entry.display_name %></p>
            <p class="caption mb-0"><%= entry.phone_number %> · <%= pluralize(entry.party_size, "guest") %></p>
          </div>
        </div>
      </div>
    <% end %>
  <% else %>
    <p class="caption mb-4">No group <%= status %>.</p>
  <% end %>
<% end %>
