<div class="card mb-2">
  <div class="card-body d-flex justify-content-between align-items-center">
    <div>
      <p class="mb-0 fw-bold">#<%= position %> · <%= entry.display_name %></p>
      <p class="caption mb-0"><%= entry.display_phone %> · <%= pluralize(entry.party_size, "guest") %></p>
      <p class="caption mb-0"><%= time_ago_in_words(entry.waiting_since) %> ago</p>
    </div>
    <span class="badge-status badge-<%= entry.status %>"><%= entry.status.capitalize %></span>
  </div>
</div>
