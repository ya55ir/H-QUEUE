<%# Style guide : référence vivante des composants H-Queue. Mobile first (390px). %>
<div style="max-width: 390px; margin: 0 auto;">
  <%= render "shared/page_title", title: "Style Guide", subtitle: "H-Queue components reference." %>

  <%# ---------- LOGO ---------- %>
  <h2 class="h5 mt-4 mb-2">Logo</h2>
  <div class="bg-dark p-3 rounded">
    <span class="logo"><span class="logo-h">H</span><span class="logo-q">Q</span></span>
  </div>

  <%# ---------- BUTTONS ---------- %>
  <h2 class="h5 mt-4 mb-2">Buttons</h2>
  <div class="d-grid gap-2">
    <button class="btn btn-primary">Join the virtual queue</button>
    <button class="btn btn-outline-brand">See other venues</button>
    <button class="btn btn-link">Forgot my password</button>
  </div>

  <%# ---------- FORM ---------- %>
  <h2 class="h5 mt-4 mb-2">Form fields</h2>
  <%# 1. Default : icône gauche décorative, bouton géoloc à droite %>
  <p class="text-dark small mb-1">Default + left icon & geo button</p>
  <div class="field-control mb-3">
    <i class="fa-solid fa-magnifying-glass field-icon field-icon-left"></i>
    <input type="text" class="form-control" placeholder="75017 Paris">
    <button type="button" aria-label="Use my location"
            class="fa-solid fa-fw fa-location-crosshairs field-icon field-icon-right"></button>
  </div>

  <%# 2. Active : saisie en cours, bouton clear à droite %>
  <p class="text-dark small mb-1">Active + left icon & clear button</p>
  <div class="field-control mb-3">
    <i class="fa-solid fa-magnifying-glass field-icon field-icon-left"></i>
    <input type="text" class="form-control is-active" value="75017 Paris" placeholder="75017 Paris">
    <button type="button" aria-label="Clear search"
            class="fa-solid fa-circle-xmark field-icon field-icon-right"></button>
  </div>

  <%# 3. Locating : spinner pendant getCurrentPosition %>
  <p class="text-dark small mb-1">Locating</p>
  <div class="field-control mb-3">
    <i class="fa-solid fa-magnifying-glass field-icon field-icon-left"></i>
    <input type="text" class="form-control" placeholder="Search by name or address...">
    <button type="button" aria-label="Locating" disabled
            class="fa-solid fa-fw fa-spinner field-icon field-icon-right field-icon-spin"></button>
  </div>

  <%# 4. Geolocated : pin + libellé figé, champ readonly %>
  <p class="text-dark small mb-1">Geolocated (readonly)</p>
  <div class="field-control mb-3">
    <i class="fa-solid fa-location-dot field-icon field-icon-left"></i>
   <input type="text" class="form-control is-locked" value="Around you" readonly>
    <button type="button" aria-label="Clear search"
            class="fa-solid fa-circle-xmark field-icon field-icon-right"></button>
  </div>

  <%# 5. Default avec label, sans icône %>
  <p class="text-dark small mb-1">Default + label</p>
  <label class="form-label" for="guests">Number of guests</label>
  <input type="text" id="guests" class="form-control mb-3" placeholder="How many are you?">

  <%# 6. Filled avec label, téléphone %>
  <p class="text-dark small mb-1">Filled + label</p>
  <label class="form-label" for="phone_number">Phone number</label>
  <input type="tel" id="phone_number" class="form-control" value="+33 6 12 34 56 78" placeholder="+33 6 12 34 56 78">

  <%# ---------- BADGE ---------- %>
  <h2 class="h5 mt-4 mb-2">Cuisine badge</h2>
  <span class="badge-cuisine d-inline-block">French</span>

  <%# ---------- BADGE STATUS ---------- %>
  <h2 class="h5 mt-4 mb-2">Queue status badge</h2>
  <span class="badge-status badge-waiting d-inline-block me-1">Waiting</span>
  <span class="badge-status badge-notified d-inline-block me-1">Notified</span>
  <span class="badge-status badge-confirmed d-inline-block">Confirmed</span>

  <%# ---------- NAVBAR (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">Navbar <small class="text-secondary">partial</small></h2>
  <%= render "shared/navbar" %>

  <%# ---------- FOOTER (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">Footer <small class="text-secondary">partial</small></h2>
  <%= render "shared/footer" %>

  <%# ---------- PAGE TITLE (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">Page title <small class="text-secondary">partial</small></h2>
  <%= render "shared/page_title", title: "Find your spot", subtitle: "Search a venue and skip the line." %>

  <%# ---------- COUNTER (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">Counter <small class="text-secondary">partial</small></h2>
  <%= render "shared/counter", count: 12, label: "groups in the queue", wait: 10 %>

  <%# ---------- FEEDBACK (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">Feedback <small class="text-secondary">partial</small></h2>
  <%= render "shared/feedback",
        icon: "store",
        title: "No venues yet",
        subtitle: "Search a venue or share your location to see venues around you." %>

  <%# ---------- PWA INSTALL BANNER (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">PWA install banner <small class="text-secondary">partial — iOS only</small></h2>
  <p class="caption mb-2">Masquée par défaut, affichée en JS uniquement sur iPhone/iPad non installé (cf. <code>pwa_install_controller.js</code>).</p>
  <%= render "shared/pwa_install_banner" %>
  <button type="button" class="btn btn-outline-brand btn-sm" data-bs-toggle="modal" data-bs-target="#pwa-install-modal">
    Voir la modal d'instructions
  </button>

  <%# ---------- VENUE CARD (partial) ---------- %>
  <h2 class="h5 mt-4 mb-2">Venue card <small class="text-secondary">partial</small></h2>
    <p class="text-dark small mb-1 mt-3">Without photo</p>
    <%= render "shared/venue_card", venue: @sample_venue_without_photo, path: "#" %>
    <p class="text-dark small mb-1">Default</p>
    <%= render "shared/venue_card", venue: @sample_venue %>
    <p class="text-dark small mb-1 mt-3">With distance</p>
    <%= render "shared/venue_card", venue: @sample_venue, distance: "0.5" %>
    <p class="text-dark small mb-1 mt-3">With queue count (manager view)</p>
    <%= render "shared/venue_card", venue: @sample_venue, path: "#", queue_count: 4 %>
</div>
