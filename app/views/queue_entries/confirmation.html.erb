<%= render "shared/live_venue_queue", venue: @queue_entry.venue %>

<% if @queue_entry.waiting? %>
  <%= render "shared/page_title", title: @queue_entry.venue.name, subtitle: "Grab a drink nearby, we've got your spot" %>

  <%= render "shared/feedback",
        icon: "circle-check",
        title: "You are in the virtual queue",
        subtitle: "You will receive a notification 10 minutes before your table is ready!" %>

  <%= render "shared/counter",
        count: @queue_entry.tables_ahead,
        label: @queue_entry.tables_ahead.positive? ? "#{'group'.pluralize(@queue_entry.tables_ahead)} ahead of you" : "You're next!",
        wait: @queue_entry.venue.avg_wait_minutes %>

<% elsif @queue_entry.notified? %>
  <%= render "shared/page_title", title: @queue_entry.venue.name, subtitle: "Almost there, are you coming?" %>

  <%= render "shared/feedback",
        icon: "chair",
        title: "Your table will be ready in #{@queue_entry.venue.avg_wait_minutes} minutes",
        subtitle: "Please confirm your arrival." %>

  <%= button_to "Confirm", confirm_queue_entry_path(@queue_entry), method: :patch, class: "btn btn-primary w-100 mb-2" %>
  <%= button_to "Cancel", decline_queue_entry_path(@queue_entry), method: :patch, class: "btn btn-outline-brand w-100" %>

<% elsif @queue_entry.confirmed? %>
  <%= render "shared/page_title", title: @queue_entry.venue.name, subtitle: "See you in a minute!" %>

  <%= render "shared/feedback",
        icon: "utensils",
        title: "Thank you #{@queue_entry.name.presence || @queue_entry.user&.first_name}",
        subtitle: "Your table is waiting for you." %>
<% end %>