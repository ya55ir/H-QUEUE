<% if @queue_entry.waiting? %>
  <%= render "shared/page_title", title: @queue_entry.venue.name, subtitle: "Grab a drink nearby, we've got your spot" %>

  <div class="text-center mb-4">
    <p>You are in the virtual queue.</p>
    <p class="text-secondary">You will receive a notification 10 minutes before your table is ready!</p>
  </div>

  <%= render "shared/counter", count: @queue_entry.tables_ahead, wait: @queue_entry.venue.avg_wait_minutes %>

<% elsif @queue_entry.notified? %>
  <%= render "shared/page_title", title: @queue_entry.venue.name, subtitle: "Almost there, are you coming?" %>

  <div class="text-center mb-4">
    <p>Your table will be ready in <%= @queue_entry.venue.avg_wait_minutes %> minutes.</p>
    <p class="text-secondary">Please confirm your arrival.</p>
  </div>

  <%= button_to "Confirm", confirm_queue_entry_path(@queue_entry), method: :patch, class: "btn btn-primary w-100 mb-2" %>
  <%= button_to "Cancel", decline_queue_entry_path(@queue_entry), method: :patch, class: "btn btn-outline-brand w-100" %>

<% elsif @queue_entry.confirmed? %>
  <%= render "shared/page_title", title: @queue_entry.venue.name, subtitle: "See you in a minute!" %>

  <div class="text-center">
    <p>Thank you <%= @queue_entry.name.presence || @queue_entry.user&.first_name %>.</p>
    <p class="text-secondary">Your table is waiting for you.</p>
  </div>
<% end %>
